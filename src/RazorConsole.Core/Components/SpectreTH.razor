@namespace RazorConsole.Components

@using Spectre.Console

<th data-align="@AlignAttribute"
    data-width="@Width"
    data-padding="@PaddingAttribute"
    data-no-wrap="@NoWrapAttribute"
    @attributes="AdditionalAttributes">
    @ChildContent
</th>

@code {

    /// <summary>
    /// Table header cell for <see cref="SpectreTable"/>.
    /// </summary>
    /// <remarks>
    /// Use within <see cref="SpectreTR"/> in <see cref="SpectreTHead"/> to define column headers.
    /// </remarks>

    /// <summary>
    /// Content of the header cell.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Horizontal alignment of the header cell content. Options: <see cref="Justify.Left"/>, <see cref="Justify.Center"/>, <see cref="Justify.Right"/>. If <c>null</c>, uses default.
    /// </summary>
    [Parameter]
    public Justify? Align { get; set; }

    /// <summary>
    /// The width of the column.
    /// </summary>
    [Parameter]
    public int? Width { get; set; }

    /// <summary>
    /// The padding of the column.
    /// </summary>
    [Parameter]
    public Padding? Padding { get; set; }

    /// <summary>
    /// No wrap flag. If true, then text doesn't wrap in column.
    /// </summary>
    /// <remarks>
    /// By default, is false
    /// </remarks>
    [Parameter]
    public bool NoWrap { get; set; }

    /// <summary>
    /// Additional HTML attributes for the th element.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object?>? AdditionalAttributes { get; set; }

    private string? AlignAttribute => Align switch
    {
        Justify.Left => "left",
        Justify.Right => "right",
        Justify.Center => "center",
        _ => null,
    };

    private string? PaddingAttribute => Padding.HasValue
        ? $"{Padding.Value.Left},{Padding.Value.Top},{Padding.Value.Right},{Padding.Value.Bottom}"
        : null;

    private string NoWrapAttribute => NoWrap.ToString().ToLower();

}
